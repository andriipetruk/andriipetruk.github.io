---
layout: default
---
<section class="hero">
  <div class="hero-grid">
    <div class="hero-text">
      <p class="hero-eyebrow">Systems Researcher · Infrastructure Architect</p>

      <h1 class="hero-name">
        <span>Andrii</span>
        <span>Petruk</span>
      </h1>

      <p class="hero-tagline">
        {{ page.tagline | default: "Building trustworthy intelligent systems at the intersection of AI, infrastructure, and architecture." }}
      </p>

      <ul class="hero-pillars">
        <li><span class="pillar-num">01</span><span class="pillar-text">LLM Reasoning &amp; Safety</span></li>
        <li><span class="pillar-num">02</span><span class="pillar-text">Cloud-Native Architecture</span></li>
        <li><span class="pillar-num">03</span><span class="pillar-text">Autonomous Infrastructure</span></li>
      </ul>

      <nav class="hero-cta" aria-label="Primary">
        <a class="hero-cta-link" href="{{ '/research/' | relative_url }}">Papers <span aria-hidden="true">→</span></a>
        <a class="hero-cta-link" href="{{ '/essays/' | relative_url }}">Writing <span aria-hidden="true">→</span></a>
        <a class="hero-cta-link" href="{{ '/projects/' | relative_url }}">Projects <span aria-hidden="true">→</span></a>
        <a class="hero-cta-link" href="mailto:{{ site.data.socials.email }}">Work With Me <span aria-hidden="true">→</span></a>
      </nav>
    </div>

    <div class="hero-portrait">
      {% if page.profile and page.profile.image %}
        {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
        {% capture sizes %}(min-width: 992px) 380px, (min-width: 576px) 40vw, 70vw{% endcapture %}
        {%
          include figure.liquid
            loading="eager"
            path=profile_image_path
            class="hero-portrait-img"
            sizes=sizes
            alt="Portrait of Andrii Petruk"
            cache_bust=true
        %}
      {% endif %}
    </div>
  </div>

  {% if content and content != "" %}
    <div class="hero-note">{{ content }}</div>
  {% endif %}

  <div class="hero-meta">
    <div class="hero-socials">{% social_links %}</div>
    <p class="hero-contact-note">{{ site.contact_note }}</p>
  </div>
</section>
